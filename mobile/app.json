{
  "expo": {
    "name": "Claro",
    "slug": "claro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1B4965"
    },
    "plugins": [
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "app.opusworks.claro",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Claro needs camera access to photograph immigration documents for on-device scanning.",
        "NSPhotoLibraryUsageDescription": "Claro needs photo library access so you can select document photos for scanning."
      }
    },
    "android": {
      "package": "app.opusworks.claro",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F6EFE2"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "bd086ef3-ef98-4a10-b783-90c1c3571151"
      }
    },
    "owner": "bscdevgroups-organization"
  }
}
